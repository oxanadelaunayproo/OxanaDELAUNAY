<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Oxana Delaunay — Chargée de Marketing Digital & Événementiel</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Poppins:ital,wght@0,300;0,400;0,500;0,600;0,700;0,800;1,400&display=swap" rel="stylesheet">
<style>
  :root {
    --bg: #f0edf8;
    --bg2: #ece8f5;
    --white: #ffffff;
    --dark: #12102a;
    --mid: #4a4769;
    --light: #8e8aab;
    --gradient: linear-gradient(135deg, #ff7043 0%, #ff4081 50%, #e91e8c 100%);
    --gradient-btn: linear-gradient(135deg, #ff8c42 0%, #e91e8c 100%);
    --purple: #7c3aed;
    --purple-light: #ede9fe;
    --purple-mid: #a78bfa;
    --orange: #ff7043;
    --pink: #e91e8c;
    --border: #e0dbf0;
    --card-shadow: 0 8px 32px rgba(124,58,237,0.08);
  }
  * { margin:0; padding:0; box-sizing:border-box; }
  html { scroll-behavior:smooth; }
  body { font-family:'Poppins',sans-serif; background:var(--bg); color:var(--dark); overflow-x:hidden; }

  /* NAV */
  nav {
    position:fixed; top:0; left:0; right:0; z-index:100;
    display:flex; align-items:center; justify-content:space-between;
    padding:1rem 5vw;
    background:rgba(240,237,248,0.92); backdrop-filter:blur(14px);
    border-bottom:1px solid rgba(255,255,255,0.6); transition:box-shadow 0.3s;
  }
  nav.scrolled { box-shadow:0 2px 20px rgba(124,58,237,0.1); }
  .nav-logo {
    font-size:1.4rem; font-weight:800; text-decoration:none;
    background:var(--gradient); -webkit-background-clip:text; -webkit-text-fill-color:transparent;
  }
  .nav-links { display:flex; gap:2.2rem; list-style:none; }
  .nav-links a { font-size:0.88rem; font-weight:500; color:var(--mid); text-decoration:none; transition:color 0.2s; }
  .nav-links a:hover { color:var(--orange); }
  .nav-cta {
    background:var(--gradient-btn); color:#fff;
    padding:0.55rem 1.4rem; border-radius:50px;
    font-size:0.82rem; font-weight:600; text-decoration:none;
    box-shadow:0 4px 15px rgba(233,30,140,0.3); transition:opacity 0.2s, transform 0.2s;
  }
  .nav-cta:hover { opacity:0.9; transform:translateY(-1px); }
  .burger { display:none; flex-direction:column; gap:5px; cursor:pointer; }
  .burger span { width:22px; height:2px; background:var(--dark); border-radius:2px; transition:0.3s; }
  .nav-mobile { display:none; }

  /* HERO */
  #accueil {
    min-height:100vh; padding:110px 5vw 80px;
    display:grid; grid-template-columns:1.1fr 0.9fr; gap:3rem; align-items:center;
    background:linear-gradient(160deg, #f5f2fc 0%, #ece8f5 40%, #fce8f3 100%);
  }
  .badge-dispo {
    display:inline-flex; align-items:center; gap:0.5rem;
    background:var(--gradient-btn); color:#fff;
    padding:0.45rem 1.1rem; border-radius:50px; font-size:0.8rem; font-weight:600;
    margin-bottom:1.8rem; box-shadow:0 4px 16px rgba(233,30,140,0.3);
    animation:fadeUp 0.5s ease both;
  }
  .badge-dot { width:7px; height:7px; border-radius:50%; background:#fff; animation:blink 2s infinite; }
  @keyframes blink { 0%,100%{opacity:1} 50%{opacity:0.3} }
  .hero-name { font-size:clamp(2.8rem,6vw,5.5rem); font-weight:800; line-height:1.05; color:var(--dark); animation:fadeUp 0.5s 0.1s ease both; }
  .hero-name .grad { background:var(--gradient); -webkit-background-clip:text; -webkit-text-fill-color:transparent; }
  .hero-subtitle {
    font-size:0.85rem; font-weight:600; letter-spacing:0.1em; text-transform:uppercase;
    color:var(--orange); margin:1rem 0 1.3rem; animation:fadeUp 0.5s 0.15s ease both;
  }
  .hero-desc { font-size:1rem; line-height:1.8; color:var(--mid); max-width:520px; animation:fadeUp 0.5s 0.2s ease both; }
  .hero-desc strong { color:var(--dark); }
  .hero-btns { display:flex; gap:1rem; flex-wrap:wrap; margin-top:2rem; animation:fadeUp 0.5s 0.25s ease both; }
  .btn-grad {
    background:var(--gradient-btn); color:#fff; padding:0.85rem 2rem; border-radius:50px;
    font-size:0.9rem; font-weight:600; text-decoration:none;
    box-shadow:0 6px 20px rgba(233,30,140,0.3); transition:opacity 0.2s, transform 0.2s;
  }
  .btn-grad:hover { opacity:0.9; transform:translateY(-2px); }
  .btn-outline {
    background:transparent; color:var(--dark); padding:0.85rem 2rem; border-radius:50px;
    font-size:0.9rem; font-weight:600; text-decoration:none;
    border:2px solid var(--dark); transition:all 0.2s;
  }
  .btn-outline:hover { border-color:var(--orange); color:var(--orange); transform:translateY(-2px); }
  .hero-stats { display:flex; gap:1.2rem; margin-top:2.5rem; flex-wrap:wrap; animation:fadeUp 0.5s 0.3s ease both; }
  .stat-card {
    background:var(--white); border-radius:16px; padding:1.2rem 1.5rem;
    box-shadow:var(--card-shadow); flex:1; min-width:110px;
  }
  .stat-num { font-size:1.8rem; font-weight:800; background:var(--gradient); -webkit-background-clip:text; -webkit-text-fill-color:transparent; line-height:1; }
  .stat-lbl { font-size:0.72rem; color:var(--light); margin-top:0.3rem; font-weight:500; }
  .hero-card {
    background:var(--white); border-radius:24px; padding:2rem;
    box-shadow:0 16px 60px rgba(124,58,237,0.12); animation:fadeUp 0.5s 0.2s ease both;
    position:relative; overflow:hidden;
  }
  .hero-card::before { content:''; position:absolute; top:0; left:0; right:0; height:4px; background:var(--gradient); }
  .contact-row { display:flex; align-items:center; gap:1rem; padding:0.8rem 0; border-bottom:1px solid var(--border); }
  .contact-row:last-child { border-bottom:none; }
  .contact-icon {
    width:44px; height:44px; border-radius:12px; flex-shrink:0;
    background:linear-gradient(135deg,#7c3aed,#a855f7);
    display:flex; align-items:center; justify-content:center; font-size:1.1rem;
  }
  .contact-lbl { font-size:0.72rem; color:var(--light); font-weight:500; }
  .contact-val { font-size:0.88rem; font-weight:600; color:var(--dark); }
  .contact-val.pink { color:var(--pink); }
  @keyframes fadeUp { from{opacity:0;transform:translateY(20px)} to{opacity:1;transform:translateY(0)} }

  /* SECTIONS */
  section { padding:90px 5vw; }
  .s-label {
    font-size:0.72rem; font-weight:700; letter-spacing:0.2em; text-transform:uppercase;
    background:var(--gradient); -webkit-background-clip:text; -webkit-text-fill-color:transparent;
    margin-bottom:0.5rem; display:inline-block;
  }
  .s-title { font-size:clamp(1.8rem,4vw,2.8rem); font-weight:800; color:var(--dark); line-height:1.2; }
  .s-sub { font-size:0.93rem; color:var(--light); margin-top:0.7rem; max-width:540px; line-height:1.7; }
  .s-head { margin-bottom:3.5rem; }

  /* COMPÉTENCES */
  #competences { background:var(--white); }
  .skills-grid { display:grid; grid-template-columns:repeat(auto-fit,minmax(270px,1fr)); gap:1.3rem; }
  .skill-card {
    background:var(--bg); border-radius:20px; padding:1.8rem;
    border:1px solid var(--border); transition:all 0.3s; position:relative; overflow:hidden;
  }
  .skill-card::after {
    content:''; position:absolute; bottom:0; left:0; right:0; height:3px;
    background:var(--gradient); transform:scaleX(0); transform-origin:left; transition:transform 0.3s;
  }
  .skill-card:hover { transform:translateY(-4px); box-shadow:0 16px 40px rgba(124,58,237,0.12); }
  .skill-card:hover::after { transform:scaleX(1); }
  .sk-icon {
    width:48px; height:48px; border-radius:14px;
    background:linear-gradient(135deg,#7c3aed,#a855f7);
    display:flex; align-items:center; justify-content:center; font-size:1.3rem; margin-bottom:1rem;
  }
  .sk-name { font-weight:700; font-size:0.95rem; margin-bottom:0.5rem; }
  .sk-desc { font-size:0.82rem; color:var(--light); line-height:1.65; }
  .tools-wrap { margin-top:3.5rem; }
  .tools-lbl { font-size:0.72rem; font-weight:700; letter-spacing:0.15em; text-transform:uppercase; color:var(--mid); margin-bottom:1rem; }
  .tools-row { display:flex; flex-wrap:wrap; gap:0.6rem; }
  .tool {
    background:var(--bg); border:1.5px solid var(--border); padding:0.4rem 1rem; border-radius:50px;
    font-size:0.8rem; font-weight:500; color:var(--mid); transition:all 0.2s;
  }
  .tool:hover { border-color:var(--purple); color:var(--purple); background:var(--purple-light); }

  /* EXPÉRIENCES */
  #experience { background:var(--bg); }
  .xp-list { display:flex; flex-direction:column; gap:2rem; }
  .xp-card {
    background:var(--white); border-radius:24px; padding:2.2rem;
    box-shadow:var(--card-shadow); border:1px solid var(--border);
    transition:box-shadow 0.3s; position:relative; overflow:hidden;
  }
  .xp-card::before { content:''; position:absolute; left:0; top:0; bottom:0; width:4px; background:var(--gradient); }
  .xp-card:hover { box-shadow:0 16px 50px rgba(124,58,237,0.14); }
  .xp-date {
    display:inline-block; background:var(--purple-light); color:var(--purple);
    padding:0.3rem 0.9rem; border-radius:50px; font-size:0.75rem; font-weight:700; margin-bottom:0.8rem;
  }
  .xp-title { font-size:1.2rem; font-weight:700; color:var(--dark); margin-bottom:0.2rem; }
  .xp-co { font-size:0.85rem; color:var(--light); margin-bottom:1.2rem; }
  .xp-ul { list-style:none; margin-bottom:1.5rem; }
  .xp-ul li {
    font-size:0.88rem; color:var(--mid); line-height:1.65;
    padding:0.35rem 0 0.35rem 1.3rem; position:relative; border-bottom:1px solid var(--border);
  }
  .xp-ul li:last-child { border-bottom:none; }
  .xp-ul li::before {
    content:'→'; position:absolute; left:0;
    background:var(--gradient); -webkit-background-clip:text; -webkit-text-fill-color:transparent;
    font-weight:700; font-size:0.8rem;
  }
  .xp-kpis { display:flex; flex-wrap:wrap; gap:0.7rem; }
  .kpi { background:linear-gradient(135deg,#fef3c7,#fde68a); padding:0.35rem 0.9rem; border-radius:8px; font-size:0.78rem; font-weight:700; color:#92400e; }

  /* PORTFOLIO */
  #portfolio { background:var(--white); }
  .port-grid { display:grid; grid-template-columns:repeat(auto-fit,minmax(300px,1fr)); gap:1.3rem; }
  .port-card { background:var(--bg); border-radius:20px; overflow:hidden; border:1px solid var(--border); transition:all 0.3s; }
  .port-card:hover { transform:translateY(-5px); box-shadow:0 20px 50px rgba(124,58,237,0.13); }
  .port-top { height:150px; display:flex; align-items:center; justify-content:center; position:relative; overflow:hidden; }
  .pt1{background:linear-gradient(135deg,#0077B5,#005f99)} .pt2{background:linear-gradient(135deg,#ff7043,#e91e8c)}
  .pt3{background:linear-gradient(135deg,#10b981,#059669)} .pt4{background:linear-gradient(135deg,#f59e0b,#d97706)}
  .pt5{background:linear-gradient(135deg,#7c3aed,#6d28d9)} .pt6{background:linear-gradient(135deg,#06b6d4,#0891b2)}
  .port-icon { font-size:3.5rem; opacity:0.25; filter:brightness(0) invert(1); }
  .port-badge {
    position:absolute; bottom:10px; right:10px;
    background:rgba(255,255,255,0.2); backdrop-filter:blur(8px);
    padding:0.3rem 0.8rem; border-radius:20px; color:#fff; font-size:0.75rem; font-weight:700;
  }
  .port-body { padding:1.4rem; }
  .port-cat { font-size:0.7rem; font-weight:700; letter-spacing:0.1em; text-transform:uppercase; background:var(--gradient); -webkit-background-clip:text; -webkit-text-fill-color:transparent; margin-bottom:0.4rem; }
  .port-title { font-weight:700; font-size:0.95rem; margin-bottom:0.5rem; color:var(--dark); }
  .port-desc { font-size:0.82rem; color:var(--light); line-height:1.6; margin-bottom:1rem; }
  .port-tags { display:flex; flex-wrap:wrap; gap:0.4rem; }
  .port-tag { background:var(--white); border:1px solid var(--border); padding:0.22rem 0.65rem; border-radius:50px; font-size:0.72rem; color:var(--mid); font-weight:500; }

  /* LANGUES */
  #langues { background:var(--bg); }
  .lang-grid { display:flex; flex-wrap:wrap; gap:1.3rem; }
  .lang-card {
    flex:1; min-width:200px; background:var(--white); border-radius:20px;
    padding:2rem; text-align:center; border:1px solid var(--border);
    box-shadow:var(--card-shadow); transition:all 0.3s;
  }
  .lang-card:hover { transform:translateY(-3px); box-shadow:0 12px 35px rgba(124,58,237,0.14); }
  .lang-flag { font-size:2.5rem; margin-bottom:0.8rem; }
  .lang-name { font-weight:700; font-size:1rem; margin-bottom:0.2rem; }
  .lang-lvl { font-size:0.8rem; color:var(--light); margin-bottom:1.2rem; }
  .lang-bar { height:6px; background:var(--border); border-radius:6px; overflow:hidden; }
  .lang-fill { height:100%; background:var(--gradient); border-radius:6px; }

  /* FORMATION */
  #formation { background:var(--white); }
  .edu-grid { display:grid; grid-template-columns:1fr 1fr; gap:1.3rem; }
  .edu-card {
    background:var(--bg); border-radius:20px; padding:2rem; border:1px solid var(--border);
    transition:all 0.3s; position:relative; overflow:hidden;
  }
  .edu-card::before { content:''; position:absolute; top:0; left:0; right:0; height:4px; background:var(--gradient); }
  .edu-card:hover { transform:translateY(-3px); box-shadow:0 12px 35px rgba(124,58,237,0.12); }
  .edu-year { font-size:2.2rem; font-weight:800; background:var(--gradient); -webkit-background-clip:text; -webkit-text-fill-color:transparent; line-height:1; margin-bottom:1rem; }
  .edu-deg { font-weight:700; font-size:1rem; margin-bottom:0.3rem; }
  .edu-sch { font-size:0.85rem; color:var(--light); }
  .edu-badge { display:inline-block; margin-top:0.8rem; background:var(--gradient-btn); color:#fff; padding:0.2rem 0.8rem; border-radius:50px; font-size:0.7rem; font-weight:600; }

  /* TÉMOIGNAGES */
  #temoignages { background:var(--bg); }
  .testi-grid { display:grid; grid-template-columns:repeat(auto-fit,minmax(300px,1fr)); gap:1.3rem; }
  .testi-card { background:var(--white); border-radius:20px; padding:2rem; border:1px solid var(--border); box-shadow:var(--card-shadow); transition:all 0.3s; }
  .testi-card:hover { transform:translateY(-3px); box-shadow:0 12px 35px rgba(124,58,237,0.14); }
  .testi-q { font-size:3rem; line-height:1; background:var(--gradient); -webkit-background-clip:text; -webkit-text-fill-color:transparent; margin-bottom:1rem; font-weight:800; }
  .testi-txt { font-size:0.88rem; color:var(--mid); line-height:1.75; font-style:italic; margin-bottom:1.5rem; }
  .testi-author { display:flex; align-items:center; gap:0.9rem; }
  .testi-av { width:42px; height:42px; border-radius:50%; flex-shrink:0; background:var(--gradient); display:flex; align-items:center; justify-content:center; color:#fff; font-weight:700; font-size:0.82rem; }
  .testi-name { font-weight:700; font-size:0.85rem; }
  .testi-role { font-size:0.75rem; color:var(--light); }

  /* CONTACT */
  #contact { background:linear-gradient(160deg,#1a1035 0%,#2d1b5e 60%,#1a1035 100%); }
  .contact-inner { display:grid; grid-template-columns:1fr 1fr; gap:5rem; align-items:center; }
  .c-label { font-size:0.72rem; font-weight:700; letter-spacing:0.2em; text-transform:uppercase; background:var(--gradient); -webkit-background-clip:text; -webkit-text-fill-color:transparent; margin-bottom:0.6rem; display:inline-block; }
  .c-title { font-size:clamp(2rem,4vw,3rem); font-weight:800; color:#fff; line-height:1.2; margin-bottom:1rem; }
  .c-desc { font-size:0.92rem; color:rgba(255,255,255,0.5); line-height:1.75; margin-bottom:2rem; }
  .c-links { display:flex; flex-direction:column; gap:0.8rem; }
  .c-link { display:flex; align-items:center; gap:1rem; color:rgba(255,255,255,0.6); text-decoration:none; font-size:0.88rem; padding:0.7rem; border-radius:12px; transition:all 0.2s; }
  .c-link:hover { background:rgba(255,255,255,0.05); color:#fff; }
  .c-link-ico { width:38px; height:38px; border-radius:10px; background:linear-gradient(135deg,#7c3aed,#a855f7); display:flex; align-items:center; justify-content:center; font-size:1rem; flex-shrink:0; }
  .c-btns { display:flex; flex-direction:column; gap:1rem; }
  .c-btn-main { background:var(--gradient-btn); color:#fff; padding:1.1rem 2rem; border-radius:50px; font-size:0.92rem; font-weight:700; text-decoration:none; text-align:center; box-shadow:0 8px 25px rgba(233,30,140,0.4); transition:opacity 0.2s,transform 0.2s; }
  .c-btn-main:hover { opacity:0.9; transform:translateY(-2px); }
  .c-btn-li { border:2px solid rgba(255,255,255,0.2); color:rgba(255,255,255,0.7); padding:1.1rem 2rem; border-radius:50px; font-size:0.92rem; font-weight:600; text-decoration:none; text-align:center; transition:all 0.2s; }
  .c-btn-li:hover { border-color:var(--purple-mid); color:#fff; }
  .c-btn-cv { border:1.5px solid rgba(255,255,255,0.1); color:rgba(255,255,255,0.4); padding:0.9rem 2rem; border-radius:50px; font-size:0.82rem; font-weight:500; text-decoration:none; text-align:center; display:flex; align-items:center; justify-content:center; gap:0.5rem; transition:all 0.2s; }
  .c-btn-cv:hover { border-color:rgba(255,255,255,0.3); color:rgba(255,255,255,0.8); }

  /* FOOTER */
  footer { background:#0e0c1e; padding:1.8rem 5vw; display:flex; align-items:center; justify-content:space-between; flex-wrap:wrap; gap:1rem; }
  .foot-copy { font-size:0.78rem; color:rgba(255,255,255,0.25); }
  .foot-socials { display:flex; gap:0.8rem; }
  .foot-soc { width:34px; height:34px; border-radius:50%; border:1px solid rgba(255,255,255,0.1); display:flex; align-items:center; justify-content:center; color:rgba(255,255,255,0.3); text-decoration:none; font-size:0.85rem; transition:all 0.2s; }
  .foot-soc:hover { border-color:var(--purple-mid); color:var(--purple-mid); }

  /* RESPONSIVE */
  @media (max-width:860px) {
    #accueil { grid-template-columns:1fr; padding-top:100px; }
    .contact-inner { grid-template-columns:1fr; gap:3rem; }
    .edu-grid { grid-template-columns:1fr; }
    .nav-links,.nav-cta { display:none; }
    .burger { display:flex; }
    .nav-mobile.open {
      display:flex; flex-direction:column;
      position:fixed; top:64px; left:0; right:0; bottom:0;
      background:var(--bg); padding:2rem 5vw; gap:1.2rem; z-index:99;
      border-top:1px solid var(--border);
    }
    .nav-mobile a { font-size:1.1rem; font-weight:600; color:var(--dark); text-decoration:none; padding:0.8rem 0; border-bottom:1px solid var(--border); }
    .nav-mobile .mob-cta { background:var(--gradient-btn); color:#fff; padding:0.9rem; border-radius:50px; text-align:center; margin-top:0.5rem; font-weight:700; border:none; }
  }
  @media (max-width:560px) {
    section { padding:65px 5vw; }
    .hero-btns { flex-direction:column; }
    .hero-stats { flex-direction:column; }
    .stat-card { min-width:unset; }
    .port-grid,.skills-grid { grid-template-columns:1fr; }
    .lang-grid { flex-direction:column; }
  }

  /* Scroll reveal */
  .reveal { opacity:0; transform:translateY(22px); transition:opacity 0.55s ease, transform 0.55s ease, box-shadow 0.3s, border-color 0.3s; }
  .reveal.visible { opacity:1; transform:translateY(0); }
</style>
</head>
<body>

<nav id="nav">
  <a class="nav-logo" href="#accueil">OD</a>
  <ul class="nav-links">
    <li><a href="#competences">Compétences</a></li>
    <li><a href="#experience">Expérience</a></li>
    <li><a href="#portfolio">Portfolio</a></li>
    <li><a href="#formation">Formation</a></li>
    <li><a href="#contact">Contact</a></li>
  </ul>
  <a href="mailto:oxanadelaunaypro@gmail.com" class="nav-cta">Me contacter</a>
  <div class="burger" onclick="toggleMenu()"><span></span><span></span><span></span></div>
</nav>

<div class="nav-mobile" id="navMob">
  <a href="#competences" onclick="toggleMenu()">Compétences</a>
  <a href="#experience" onclick="toggleMenu()">Expérience</a>
  <a href="#portfolio" onclick="toggleMenu()">Portfolio</a>
  <a href="#formation" onclick="toggleMenu()">Formation</a>
  <a href="#langues" onclick="toggleMenu()">Langues</a>
  <a href="#contact" onclick="toggleMenu()">Contact</a>
  <a href="mailto:oxanadelaunaypro@gmail.com" class="mob-cta">Me contacter →</a>
</div>

<!-- HERO -->
<section id="accueil">
  <div>
    <div class="badge-dispo"><span class="badge-dot"></span> ✨ Disponible pour de nouveaux projets</div>
    <h1 class="hero-name">Oxana <span class="grad">Delaunay</span></h1>
    <p class="hero-subtitle">Marketing Digital · Événementiel · Île-de-France</p>
