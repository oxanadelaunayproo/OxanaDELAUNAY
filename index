<script>
  window.addEventListener('scroll', () => {
    document.getElementById('nav').classList.toggle('scrolled', window.scrollY > 20);
  });
  function toggleMenu() { document.getElementById('navMob').classList.toggle('open'); }
  document.addEventListener('click', e => {
    const m = document.getElementById('navMob');
    if (m.classList.contains('open') && !m.contains(e.target) && !e.target.closest('.burger')) m.classList.remove('open');
  });
  const obs = new IntersectionObserver(entries => {
    entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); });
  }, { threshold: 0.1 });
  document.querySelectorAll('.reveal').forEach(el => obs.observe(el));
</script>
